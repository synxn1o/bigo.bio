{
  "$schema": "https://anthropic.com/claude-code/marketplace.schema.json",
  "name": "astro-lsp-local",
  "description": "Astro language server for .astro files",
  "owner": {
    "name": "Local Project"
  },
  "plugins": [
    {
      "name": "astro-lsp",
      "source": "./",
      "description": "Astro language server for .astro files",
      "version": "1.0.0",
      "author": {
        "name": "Local Project"
      },
      "category": "development",
      "lspServers": {
        "astro": {
          "command": "astro-ls",
          "args": ["--stdio"],
          "extensionToLanguage": {
            ".astro": "astro"
          }
        }
      }
    }
  ]
}
