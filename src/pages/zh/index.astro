---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import ParticleAnimation from '../../components/ParticleAnimation.astro';
import SDGCard from '../../components/cards/SDGCard.astro';
import PlatformStatement from '../../components/PlatformStatement.astro';
import ProductCard from '../../components/cards/ProductCard.astro';
import CTACard from '../../components/CTACard.astro';
import { getTranslations } from '../../i18n/utils';
import { Image } from 'astro:assets';

export const prerender = true;

const lang = 'zh';
const t = getTranslations(lang);
---
<Layout title={t('site.title')} lang={lang}>
	<main class="grid-container main-content">
        <Hero lang={lang} />

        <!--
        <div class="animation-wrapper grid-item">
            <ParticleAnimation />
        </div>
        -->

        <div class="vision-section grid-item scroll-reveal">
            <h2 class="vision-title">{t('hook.question')}</h2>
            <p class="vision-subtext">{t('hook.subtext')}</p>
        </div>

        <div class="pillars-grid grid-item">
            <SDGCard
                label={t('sdg.medicine.label')}
                title={t('sdg.medicine.title')}
                description={t('sdg.medicine.desc')}
            />

            <SDGCard
                label={t('sdg.green.label')}
                title={t('sdg.green.title')}
                description={t('sdg.green.desc')}
            />

            <SDGCard
                label={t('sdg.hunger.label')}
                title={t('sdg.hunger.title')}
                description={t('sdg.hunger.desc')}
            />
        </div>

        <PlatformStatement set:html={t('platform.statement')} />

        <div class="products-stack grid-item">
            <ProductCard
                label={t('products.earlydrug.label')}
                title={t('products.earlydrug.title')}
                description={t('products.earlydrug.desc')}
                href="/pipeline/bp-326"
            >
                <Image slot="imageSlot" src="https://cdn.bigo.bio/images/earlydrug.png" alt="Protein Binder" inferSize={true} loading="lazy" />
            </ProductCard>

            <ProductCard
                label={t('products.nanocage.label')}
                title={t('products.nanocage.title')}
                description={t('products.nanocage.desc')}
                href="/pipeline/ribh"
            >
                <Image slot="imageSlot" src="https://cdn.bigo.bio/images/nanocage.png" alt="Nanocage Structure" inferSize={true} loading="lazy" />
            </ProductCard>

            <ProductCard
                label={t('products.enzymes.label')}
                title={t('products.enzymes.title')}
                description={t('products.enzymes.desc')}
                href="/pipeline"
            >
                <Image slot="imageSlot" src="https://cdn.bigo.bio/images/enzymes.jpg" alt="Enzyme Fold Structures" inferSize={true} loading="lazy" />
            </ProductCard>
        </div>

        <div class="explore-section grid-item scroll-reveal">
            <h2 class="explore-title">{t('explore.title')}</h2>
            <div class="pillars-grid">
                <CTACard
                    label={t('explore.pipeline.label')}
                    title={t('explore.pipeline.title')}
                    subtitle={t('explore.pipeline.subtitle')}
                    href="/pipeline"
                />
                <CTACard
                    label={t('explore.blog.label')}
                    title={t('explore.blog.title')}
                    subtitle={t('explore.blog.subtitle')}
                    href="/blog"
                />
                <CTACard
                    label={t('explore.team.label')}
                    title={t('explore.team.title')}
                    subtitle={t('explore.team.subtitle')}
                    href="/about"
                />
            </div>
        </div>
	</main>
</Layout>

<script>
    import Lenis from 'lenis';

    const lenis = new Lenis({
        duration: 0.6,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true,
        syncTouch: false,
        wheelMultiplier: 1,
    });

    function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
    }

    requestAnimationFrame(raf);
</script>

<style>
    .main-content {
        padding-bottom: 6rem;
        gap: 4rem var(--grid-gutter);
    }

    .animation-wrapper {
        height: clamp(300px, 50vh, 500px);
        position: relative;
        overflow: hidden;
        background: var(--color-grey-100);
    }

    .vision-section {
        margin-top: 2rem;
    }

    .vision-title {
        font-size: clamp(2rem, 5vw, 3rem);
        line-height: 1.2;
        font-weight: 800;
        max-width: 900px;
    }

    .vision-subtext {
        font-size: clamp(1.25rem, 2vw, 1.5rem);
        color: var(--color-grey-600);
        margin-top: 1rem;
        max-width: 800px;
        line-height: 1.5;
    }

    .pillars-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: var(--grid-gutter);
    }

    .products-stack {
        display: flex;
        flex-direction: column;
        gap: 2rem;
        margin: 4rem 0;
    }

    .explore-section {
        margin-top: 4rem;
    }

    .explore-title {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 2rem;
    }

    @media (max-width: 1024px) {
        .pillars-grid {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 640px) {
        .pillars-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
