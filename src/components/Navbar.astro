---
import { getTranslations } from '../i18n/utils';

interface Props {
    lang: 'en' | 'zh';
}

const { lang } = Astro.props;
const t = getTranslations(lang);

const currentPath = Astro.url.pathname;
---

<nav class="navbar outline">
    <div class="grid-container">
        <div class="nav-content">
            <div class="nav-logo">
                <a href={lang === 'en' ? '/' : '/zh/'} class="logo-link">BIGO BDA</a>
            </div>
            
            <div class="nav-links">
                <a href="#" class="nav-item">{t('nav.blog')}</a>
                <a href="#" class="nav-item">{t('nav.studio')}</a>
            </div>

            <div class="nav-actions">
                <div class="lang-toggle outline">
                    <a href="/" class={`lang-link ${lang === 'en' ? 'active' : ''}`} data-lang="en">EN</a>
                    <span class="separator">|</span>
                    <a href="/zh/" class={`lang-link ${lang === 'zh' ? 'active' : ''}`} data-lang="zh">中文</a>
                </div>
            </div>
        </div>
    </div>
</nav>

<style>
    .navbar {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        height: 64px;
        background-color: rgba(255, 255, 255, 0.8);
        backdrop-filter: blur(12px);
        -webkit-backdrop-filter: blur(12px);
        z-index: 1000;
        display: flex;
        align-items: center;
        border-top: none;
        border-left: none;
        border-right: none;
    }

    .nav-content {
        grid-column: span 12;
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
        gap: 2rem;
    }

    .nav-logo {
        flex: 0 0 auto;
    }

    .nav-links {
        display: flex;
        gap: 0;
        flex: 1;
        justify-content: center;
    }

    .nav-item {
        text-decoration: none;
        color: var(--color-black);
        font-weight: 700;
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        transition: all 0.2s ease;
        width: 160px;
        height: 40px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid var(--color-black);
        margin-left: -1px; /* Overlap borders */
    }

    .nav-item:hover {
        background-color: var(--color-swiss-red);
        color: var(--color-white);
        border-color: var(--color-black);
    }

    .nav-actions {
        flex: 0 0 auto;
    }

    .lang-toggle {
        display: flex;
        align-items: center;
        padding: 0;
        background-color: var(--color-white);
        font-size: 0.8rem;
        font-weight: 700;
        height: 40px;
    }

    .lang-link {
        text-decoration: none;
        color: var(--color-grey-500);
        width: 60px;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s ease;
    }

    .lang-link.active {
        color: var(--color-white);
        background-color: var(--color-black);
    }

    .lang-link:hover:not(.active) {
        background-color: var(--color-grey-100);
    }

    .separator {
        width: 1px;
        height: 20px;
        background-color: var(--color-black);
    }

    @media (max-width: 640px) {
        .nav-links {
            display: none;
        }
        .nav-content {
            grid-column: span 4;
        }
    }
</style>
