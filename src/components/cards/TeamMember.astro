---
import { Image } from 'astro:assets';

interface Props {
  name: string;
  role: string;
  bio: string;
  imageSrc?: string;
}

const { name, role, bio, imageSrc = "/favicon.svg" } = Astro.props;
---

<div class="team-member outline scroll-reveal">
    <div class="image-container">
        <Image src={imageSrc} alt={name} inferSize={true} loading="lazy" />
    </div>
    <div class="info">
        <h3 class="name">{name}</h3>
        <p class="role text-swiss-red">{role}</p>
        <p class="bio">{bio}</p>
    </div>
</div>

<style>
    .team-member {
        display: flex;
        flex-direction: column;
        background: var(--color-white);
        transition: all 0.2s ease-in-out;
        position: relative;
    }

    .team-member:hover {
        z-index: 10;
    }

    .team-member::after {
        content: '';
        position: absolute;
        inset: 0;
        border: 0 solid var(--color-black);
        pointer-events: none;
        transition: all 0.2s ease-in-out;
        z-index: 2;
    }

    .team-member:hover::after {
        border-width: 4px;
    }
    
    .image-container {
        width: 100%;
        aspect-ratio: 1 / 1;
        border-bottom: 1px solid var(--color-black);
        background: var(--color-grey-100);
        position: relative;
        overflow: hidden;
    }

    .image-container :global(img) {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        filter: grayscale(100%);
        transition: filter 0.4s ease-in-out;
    }

    .team-member:hover .image-container :global(img) {
        filter: grayscale(0%);
    }

    .info {
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .name {
        font-size: 1.5rem;
        font-weight: 800;
        line-height: 1.2;
    }

    .role {
        font-size: 0.875rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .bio {
        font-size: 0.875rem;
        color: var(--color-grey-700);
        margin-top: 0.5rem;
    }
</style>