---
interface Props {
    variant?: 'primary' | 'outline';
    href?: string;
    class?: string;
    type?: 'button' | 'submit' | 'reset';
}

const { variant = 'primary', href, class: className, type = 'button', ...rest } = Astro.props;

const Element = href ? 'a' : 'button';
---

<Element 
    href={href} 
    type={href ? undefined : type}
    class:list={['btn', variant === 'primary' ? 'btn-primary' : 'btn-outline', className]} 
    {...rest}
>
    <slot />
</Element>

<style>
    .btn {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.75rem 1.5rem;
        font-size: 1rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s ease;
        border: 1px solid var(--color-black);
        background: none;
        color: var(--color-black);
        font-family: var(--font-family);
    }

    .btn:focus-visible {
        outline: 2px solid var(--color-swiss-red);
        outline-offset: 2px;
    }

    .btn-primary {
        background-color: var(--color-swiss-red);
        color: var(--color-white);
    }

    .btn-primary:hover {
        background-color: var(--color-black);
        border-color: var(--color-black);
    }

    .btn-outline:hover {
        background-color: var(--color-black);
        color: var(--color-white);
    }

    button.btn {
        -webkit-appearance: none;
        appearance: none;
    }
</style>
