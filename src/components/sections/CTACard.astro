---
interface Props {
  label: string;
  title: string;
  subtitle: string;
  href: string;
}

const { label, title, subtitle, href } = Astro.props;
---
<a href={href} class="cta-card card-base outline scroll-reveal">
  <span class="label">{label}</span>
  <h3>{title}</h3>
  <p>{subtitle}</p>
  <div class="icon-arrow">→</div>
</a>

<style>
  .cta-card {
    border-radius: 0;
    text-decoration: none;
    color: inherit;
    position: relative;
    transition: all 0.2s ease-in-out;
  }

  .cta-card:hover,
  .cta-card:focus {
    background: var(--color-black);
    color: var(--color-white);
  }

  .label {
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-grey-600);
  }

  .cta-card:hover .label {
    color: var(--color-grey-400);
  }

  .cta-card h3 {
    font-size: 1.5rem;
    font-weight: 800;
    margin: 0;
  }

  .cta-card p {
    color: var(--color-swiss-red);
    margin: 0;
    font-weight: 600;
  }

  .icon-arrow {
    margin-top: auto;
    font-size: 1.5rem;
    font-weight: 800;
    align-self: flex-end;
  }
</style>
